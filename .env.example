# Required only for `brain digest` and the MCP `weekly_digest` tool
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# BRAIN_DB_PATH=/path/to/brain.sqlite
# PORT=3000
# HOST=127.0.0.1

# Set this to enable the /mcp HTTP endpoint for remote agents.
# Agents must send: Authorization: Bearer <your-secret>
# Leave unset to disable the endpoint entirely (local/stdio-only mode).
# MCP_SECRET=your-secret-here
